# Copy this file to .env.local and fill in your values.
# Cloud save and leaderboard features are disabled when these are absent
# (the game falls back to local IndexedDB-only mode).

# Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Settings → API → anon key)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
